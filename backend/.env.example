# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/betting-calculator

# ==================== AI Service Configuration ====================

# Gemini AI (used for /api/calculate endpoint - Kelly Criterion insights)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI Configuration (for /api/matchup endpoint)
# Required if using AI Matchup Analyzer with OpenAI provider
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic Configuration (optional - for /api/matchup endpoint with provider=claude)
# Required only if using AI Matchup Analyzer with Claude provider
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ==================== External APIs ====================

# ESPN Integration (no API key required - uses public ESPN API)
# Note: ESPN's public API is used for team statistics in legacy endpoints
# No additional configuration needed

# ==================== Security & CORS ====================

# Security
ADMIN_KEY=your_secure_admin_key_here

# CORS Configuration
# For local development: http://localhost:5173
# For production: your Vercel frontend URL (e.g., https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173

# ==================== Rate Limiting ====================

# Rate Limiting (optional)
# Window in milliseconds (default: 15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
